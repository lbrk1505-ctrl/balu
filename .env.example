# Star City Mall — Environment Configuration
# Copy this file to .env and fill in your own values.
# ⚠️  NEVER commit the actual .env file — it is in .gitignore.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Database name
DB_NAME=balaji

# HTTP server port
PORT=3000

# Secret key used to sign JWT tokens — use a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret

# Admin panel password — change this in production!
ADMIN_PASSWORD=change_me_in_production
